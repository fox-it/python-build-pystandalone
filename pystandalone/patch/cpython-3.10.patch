+static PyStatus
+pystandalone_init(_PyArgv *args)
+{
+    /* Mostly a copy from pymain_init, but with some small changes.
+       For example, use the IsolatedConfig and don't take configuration from
+       environment variables or command line argument.
+       Also don't populate sys.path. */
+    PyStatus status;
+
+    status = _PyRuntime_Initialize();
+    if (_PyStatus_EXCEPTION(status)) {
+        return status;
+    }
+
+    PyPreConfig preconfig;
+    PyPreConfig_InitIsolatedConfig(&preconfig);
+
+    status = Py_PreInitialize(&preconfig);
+    if (_PyStatus_EXCEPTION(status)) {
+        return status;
+    }
+
+    PyConfig config;
+    PyConfig_InitIsolatedConfig(&config);
+
+    config.site_import = 0;
+    config.optimization_level = 2;
+    config.module_search_paths_set = 1;
+
+    config_init_fs_encoding(&config, &_PyRuntime.preconfig);
+
+    if (args->use_bytes_argv) {
+        status = PyConfig_SetBytesArgv(&config, args->argc, args->bytes_argv);
+    }
+    else {
+        status = PyConfig_SetArgv(&config, args->argc, args->wchar_argv);
+    }
+
+    /* Not sure if it matters that this is empty. We set it to
+       skip the pyvenv.cfg lookup. Side-effect is that sys.executable is argv[0]. */
+    wchar_t *executable = config.argv.length > 0 ? config.argv.items[0] : L"";
+    PyConfig_SetString(&config, &config.executable, executable);
+    PyConfig_SetString(&config, &config.prefix, L"");
+    PyConfig_SetString(&config, &config.exec_prefix, L"");
+
+    if (_PyStatus_EXCEPTION(status)) {
+        goto done;
+    }
+
+    status = Py_InitializeFromConfig(&config);
+    if (_PyStatus_EXCEPTION(status)) {
+        goto done;
+    }
+    status = _PyStatus_OK();
+
+done:
+    PyConfig_Clear(&config);
+    return status;
+}
+
+
+static int
+pystandalone_main(_PyArgv *args)
+{
+    PyStandalone_Init();
+    if (!PyStandalone_HasBootstrap()) {
+        return pymain_main(args);
+    }
+
+    PyStatus status = pystandalone_init(args);
+    if (_PyStatus_IS_EXIT(status)) {
+        pymain_free();
+        return status.exitcode;
+    }
+    if (_PyStatus_EXCEPTION(status)) {
+        pymain_exit_error(status);
+    }
+
+    return PyRun_SimpleString("import bootstrap\n");
+}
+
